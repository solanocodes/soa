{
  "name": "@soa/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "knex migrate:latest --knexfile src/config/knexfile.ts",
    "migrate:make": "knex migrate:make --knexfile src/config/knexfile.ts",
    "seed": "knex seed:run --knexfile src/config/knexfile.ts"
  },
  "dependencies": {
    "@soa/shared": "*",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "socket.io": "^4.7.4",
    "pg": "^8.11.3",
    "knex": "^3.1.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.0",
    "multer": "^1.4.5-lts.1",
    "@aws-sdk/client-s3": "^3.500.0",
    "node-cron": "^3.0.3",
    "expo-server-sdk": "^3.7.0",
    "openai": "^4.28.0",
    "resend": "^3.2.0",
    "uuid": "^9.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^1.4.11",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
